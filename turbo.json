{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["CONVEX_DEPLOYMENT", "VITE_CONVEX_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "convex/_generated/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {}
  }
}
